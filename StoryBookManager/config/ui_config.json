  "editor_settings": {
    "use_universal_editor": true,
    "debug_mode": false
  },
  "brief": {
    "field_groups": {
      "basic_info": {
        "title": "Основная информация",
        "fields": [
          "title",
          "genre",
          "target_age",
          "language"
        ],
        "layout": "grid",
        "columns": 2
      },
      "content": {
        "title": "Содержание",
        "fields": [
          "description",
          "storybook_prompt"
        ],
        "layout": "vertical"
      },
      "characters_locations": {
        "title": "Персонажи и локации",
        "fields": [
          "main_characters",
          "main_locations"
        ],
        "layout": "vertical"
      },
      "settings": {
        "title": "Настройки публикации",
        "fields": [
          "pages_min",
          "pages_max",
          "words_per_page_min",
          "words_per_page_max"
        ],
        "layout": "grid",
        "columns": 2
      },
      "additional": {
        "title": "Дополнительно",
        "fields": [
          "moral"
        ],
        "layout": "vertical",
        "collapsible": true,
        "collapsed": false
      }
    },
    "field_config": {
      "title": {
        "widget": "entry",
        "width": 50,
        "placeholder": "Введите название сказки"
      },
      "description": {
        "widget": "text_area",
        "height": 4,
        "placeholder": "Опишите сюжет, персонажей и основные события"
      },
      "storybook_prompt": {
        "widget": "text_area",
        "height": 3,
        "placeholder": "Промпт для генерации сказки"
      },
      "main_characters": {
        "widget": "list_editor",
        "add_button_text": "+ Добавить персонажа",
        "placeholder": "Имя персонажа"
      },
      "main_locations": {
        "widget": "list_editor",
        "add_button_text": "+ Добавить локацию",
        "placeholder": "Название локации"
      },
      "genre": {
        "widget": "combobox",
        "values": [
          "сказка",
          "рассказ",
          "притча",
          "басня",
          "поэма",
          "былина"
        ],
        "readonly": false
      },
      "language": {
        "widget": "combobox",
        "values": [
          "ru",
          "en",
          "es",
          "fr",
          "de"
        ],
        "readonly": true
      },
      "target_age": {
        "widget": "combobox",
        "values": [
          "3-5 лет",
          "6-8 лет",
          "9-12 лет",
          "12+ лет"
        ],
        "readonly": false
      },
      "pages_min": {
        "widget": "spinbox",
        "width": 10
      },
      "pages_max": {
        "widget": "spinbox",
        "width": 10
      },
      "words_per_page_min": {
        "widget": "spinbox",
        "width": 10
      },
      "words_per_page_max": {
        "widget": "spinbox",
        "width": 10
      },
      "moral": {
        "widget": "text_area",
        "height": 2,
        "hidden": false,
        "placeholder": "Мораль или урок сказки (необязательно)"
      }
    }
  },
  "story": {
    "field_groups": {
      "story_header": {
        "title": "Заголовок",
        "hide_label": true,
